# Database
# Local (docker compose): port 5434
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/visit_harar
# Coolify / Docker production: direct Postgres URI (not a pooler)
# DATABASE_URL=postgresql://postgres:PASSWORD@postgres:5432/visit_harar
# Supabase (Vercel only): transaction pooler URI (port 6543)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Auth
BETTER_AUTH_SECRET=your-32-char-random-secret
BETTER_AUTH_URL=http://localhost:8080

# Media storage (default: ./uploads in project root)
UPLOAD_DIR=./uploads

# Resend (password reset + booking notifications)
RESEND_API_KEY=re_your-api-key
RESEND_FROM_EMAIL=noreply@visitharar.gov.et

# Super Admin Seed
SUPERADMIN_EMAIL=admin@visitharar.gov.et
SUPERADMIN_PASSWORD=change-this-immediately
SUPERADMIN_NAME=Super Admin

# Optional test editor seed
EDITOR_EMAIL=editor@visitharar.gov.et
EDITOR_PASSWORD=change-this-immediately
EDITOR_NAME=Bureau Editor

# App
NODE_ENV=development
APP_URL=http://localhost:8080
# Public origin for canonical/OG URLs in the browser (keep in sync with APP_URL).
# Coolify: set as a BUILD variable so it is embedded in the client bundle.
VITE_APP_URL=http://localhost:8080
# Production (Coolify): https://visitharar.raafat.site — see coolify.env.example
# Nitro preset: node-server (Coolify/Docker, default) or vercel (Vercel deploy)
# NITRO_PRESET=node-server

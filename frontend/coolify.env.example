# Paste into Coolify → Application → Environment Variables
# Domain: https://visitharar.raafat.site
#
# BUILD variables (rebuild after changing):
VITE_APP_URL=https://visitharar.raafat.site
#
# RUNTIME variables:
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/visit_harar
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=https://visitharar.raafat.site
APP_URL=https://visitharar.raafat.site
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
RESEND_API_KEY=re_your-api-key
RESEND_FROM_EMAIL=noreply@visitharar.gov.et

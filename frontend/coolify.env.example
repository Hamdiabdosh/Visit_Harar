# Paste into Coolify → Application → Environment Variables
# Domain: https://visitharar.raafat.site
#
# ── BUILD variables (mark as "Build Time" in Coolify; redeploy after changes) ──
VITE_APP_URL=https://visitharar.raafat.site
#
# ── RUNTIME variables ──
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Local media storage (mount a persistent volume at this path in Coolify)
UPLOAD_DIR=/data/uploads

# Use Coolify Postgres internal URL — NOT localhost
# Coolify → your Postgres service → Connection Details → Internal URL
DATABASE_URL=postgresql://postgres:PASSWORD@YOUR_COOLIFY_POSTGRES_HOST:5432/visit_harar

# Generate fresh for production: openssl rand -base64 32
BETTER_AUTH_SECRET=your-production-secret-here
BETTER_AUTH_URL=https://visitharar.raafat.site
APP_URL=https://visitharar.raafat.site

RESEND_API_KEY=re_your-api-key
RESEND_FROM_EMAIL=hararthelivingmuseum@gmail.com

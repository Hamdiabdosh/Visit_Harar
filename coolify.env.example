# Copy into Coolify → Environment Variables (app service).
# Mark only VITE_* vars as "Available at Buildtime" — see DEPLOY.md.

POSTGRES_PASSWORD=
BETTER_AUTH_SECRET=
VITE_APP_URL=https://visitharar.et
# Optional: only if APK is hosted elsewhere (default: /downloads/visit-harar.apk in the image)
# VITE_ANDROID_APK_URL=https://visitharar.et/downloads/visit-harar.apk
APP_URL=https://visitharar.et
BETTER_AUTH_URL=https://visitharar.et
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SUPERADMIN_EMAIL=admin@visitharar.gov.et
SUPERADMIN_PASSWORD=
SUPERADMIN_NAME=Super Admin

{
  "name": "visit-harar",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "dev:web": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/web build",
    "build:dev": "bun run --cwd apps/web build:dev",
    "start": "node apps/web/dist/server/index.mjs",
    "preview": "bun run --cwd apps/web preview",
    "mobile:dev": "bun run --cwd apps/mobile dev:clear",
    "mobile:android": "bun run --cwd apps/mobile android",
    "mobile:ios": "bun run --cwd apps/mobile ios",
    "flutter:dev": "cd apps/flutter && ../../scripts/flutter.sh run",
    "flutter:analyze": "cd apps/flutter && ../../scripts/flutter.sh analyze",
    "flutter:test": "cd apps/flutter && ../../scripts/flutter.sh test",
    "flutter:bundle": "cd apps/flutter && ../../scripts/flutter.sh build appbundle --release",
    "flutter:icons": "cd apps/flutter && ../../scripts/flutter.sh pub get && ../../scripts/flutter.sh pub run flutter_launcher_icons",
    "lint": "eslint apps/web",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:indexes": "tsx scripts/apply-indexes.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/run-all-seeds.ts",
    "db:reset": "tsx scripts/reset-db.ts",
    "db:up": "docker start visit-harar-pg 2>/dev/null || docker compose -f docker-compose.dev.yml up -d",
    "db:check": "tsx scripts/db-check.ts",
    "images:migrate": "tsx scripts/migrate-images-to-webp.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "^22.16.5",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "prettier": "^3.7.3",
    "tsx": "^4.22.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1"
  }
}
